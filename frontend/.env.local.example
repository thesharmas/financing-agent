# Copy to .env.local and fill in. .env.local is git-ignored.

# From dashboard.privy.io — the App ID for your Privy app. Public, safe to commit.
NEXT_PUBLIC_PRIVY_APP_ID=cmo97ujj6010a0clb43qbj1os

# Tempo testnet (Moderato) — https://docs.tempo.xyz/quickstart/connection-details
NEXT_PUBLIC_TEMPO_CHAIN_ID=42431
NEXT_PUBLIC_TEMPO_RPC_URL=https://rpc.moderato.tempo.xyz

# Test stablecoin on Tempo testnet — pick one from the faucet page:
#   pathUSD   0x20c0000000000000000000000000000000000000
#   AlphaUSD  0x20c0000000000000000000000000000000000001
#   BetaUSD   0x20c0000000000000000000000000000000000002
#   ThetaUSD  0x20c0000000000000000000000000000000000003
NEXT_PUBLIC_USDC_ADDRESS=0x20c0000000000000000000000000000000000000

# Decimals for the test stablecoin (verify in the contract if unsure; USDC-style is 6)
NEXT_PUBLIC_USDC_DECIMALS=6

# The wallet address that will RECEIVE payments. For dev, create a second Privy
# account with a different email and use that account's wallet address.
NEXT_PUBLIC_TREASURY_ADDRESS=
